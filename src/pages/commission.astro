    <script>
        const radioButtons = document.querySelectorAll('input[name="category"]');
        const allItems = document.querySelectorAll('.item');

        function filterItems() {
            let selectedValue = 'all'; // default fallback
            for (let radio of radioButtons) {
                if (radio.checked) {
                    selectedValue = radio.value;
                    break;
                }
            }
            for (let item of allItems) {
                const itemCategory = item.getAttribute('data-category');
                // Show item if selected category is 'all' OR item category matches selected category
                if (selectedValue === 'all' || itemCategory === selectedValue) {
                    item.style.display = '';     // revert to default display (block/inline-block as per browser)
                } else {
                    item.style.display = 'none'; // hide non-matching items
                }
            }
        }
        for (let radio of radioButtons) {
            radio.addEventListener('change', filterItems);
        }
        filterItems();
    </script>
