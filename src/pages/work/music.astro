---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Music" description="My music.">
    <section>
        <p><i>(see webamp player)</i></p>
        <div style="width:40px; height:40px; position:absolute; bottom:0px; left:0px;">
            <div id="winamp-container"></div>
            <script>
                const Winamp = window.Webamp;
                const webamp = new Webamp({
                    initialTracks: [
                        { 
                            metaData: { title: "quickie", }, url: "/src/assets/lib/audio/quickie.wav", }, {
                        },
                    ],
                    initialSkin: { url: "/src/assets/lib/makemesad.wsz" },
                });
                webamp.renderWhenReady(document.getElementById('winamp-container'));
            </script>
        </div>
