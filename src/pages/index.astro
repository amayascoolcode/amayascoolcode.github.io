---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import Button from '../assets/img/button.gif';
---
<Layout title="Home" description="Welcome to the dungeon.">
	<section class="text-center">
		<small>This site contains mature content. AI/repost/reuse is prohibited.</small>
		<p>Welcome to the dungeon, a world of magickal, emo juujin. <i class="fas fa-star"></i></p>
		<Image src={Button} alt="Website button" class="m-auto" />
		<script type="text/javascript" src="//counter1.fc2.com/counter.php?id=40502263&main=1"></script><noscript><img src="//counter1.fc2.com/counter_img.php?id=40502263&main=1" /></noscript>
		<div class="flex justify-center">
			<div id="contain_moon"><div><div style="padding:18px;filter:drop-shadow(0 0 18px hsl(298,100%,28%))"></div><div></div><div></div></div><script>(function(){var d=new Date().getDate();var m=document.querySelectorAll("#contain_moon div");var a=new XMLHttpRequest();var url="https://www.icalendar37.net/lunar/api/?lang=en&month="+(new Date().getMonth()+1)+"&year="+(new Date().getFullYear())+"&size=30&lightColor=rgb(211,183,227)&shadeColor=rgb(0,0,0)&LDZ="+new Date(new Date().getFullYear(),new Date().getMonth(),1)/1000+"";m[1].style.height="60px";a.onreadystatechange=function(){if(a.readyState==4&&a.status==200){var b=JSON.parse(a.responseText);m[1].innerHTML=b.phase[d].svg;if(typeof moon_widget_loaded=="function")moon_widget_loaded(b)}};a.open("GET",url,true);a.send()})()</script>
		</div>
	</section>
	<section>
		<!-- <iframe scrolling="no" style="border: 0;width: 100%;height: 50px;" src="https://bandcamp.com/band_follow_button_deluxe/2580267502"></iframe> -->
	</section>
</Layout>